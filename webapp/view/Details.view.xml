<mvc:View
    controllerName="sapui5.casestudy.casestudy.controller.Details"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:fd="sap.f"
    height="100%">

    <fd:DynamicPage id="dynamicPageId" showFooter= "true">

        <fd:title>
            <fd:DynamicPageTitle>
                <fd:heading>
                    <Title text="Detail" level="H1" titleStyle="H1"/>
                </fd:heading>
            </fd:DynamicPageTitle>
        </fd:title>

        <fd:content>

            <VBox>

                <f:SimpleForm
                    id="orderDetailForm"
                    width="auto"
                    title="Order Detail"                
                    labelSpanL="4"
                    labelSpanM="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    columnsL="1"
                    columnsM="1"
                    class="sapUiResponsiveMargin">

                    <f:content>
                        <Label text="Order Number:"/>
                        <Text text="012201"/>

                        <Label text="Created On:"/>
                        <Text text="01 Jan 2025"/>

                        <Label text="Receiving Plant:"/>
                        <Text text="9101 - Singapore"/>

                        <Label text="Delivering Plant:"/>
                        <Text text="9102 - Malaysia"/>

                        <Label text="Status:"/>
                        <Text text="Created"/>
                    </f:content>

                </f:SimpleForm>

                <!-- Products Table -->
                <Table
                    id="idProductsTable"
                    headerText="Product (3)"
                    width="auto"
                    class="sapUiResponsiveMargin sapUiLargePaddingTop"
>

                    <columns>
                        <Column width="12em">
                            <Text text="Product Name"/>
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="Quantity"/>
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true" hAlign="End">
                            <Text text="Price Per Quantity"/>
                        </Column>
                        <Column hAlign="End">
                            <Text text="Total Price"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="P002 - Sony Bravia TV"/>
                                <Text text="1"/>
                                <Text text="30000"/>
                                <Text text="30000"/>
                            </cells>
                        </ColumnListItem>
                        <ColumnListItem>
                            <cells>
                                <Text text="P109 - Samsung TV"/>
                                <Text text="2"/>
                                <Text text="50000"/>
                                <Text text="100000"/>
                            </cells>
                        </ColumnListItem>
                        <ColumnListItem>
                            <cells>
                                <Text text="P385 - Phillips TV"/>
                                <Text text="1"/>
                                <Text text="35000"/>
                                <Text text="35000"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </fd:content>

        <fd:footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="Edit"/>
                <Button text="Cancel"/>
            </OverflowToolbar>
        </fd:footer>

    </fd:DynamicPage>

</mvc:View>