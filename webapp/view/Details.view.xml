<mvc:View
    controllerName="sapui5.casestudy.casestudy.controller.Details"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:fd="sap.f"
    height="100%">

    <fd:DynamicPage id="dynamicPageDetailsId" showFooter= "true">

        <fd:title>
            <fd:DynamicPageTitle>
                <fd:heading>
                    <Title text="{i18n>titleDetails}" level="H1" titleStyle="H1"/>
                </fd:heading>
            </fd:DynamicPageTitle>
        </fd:title>

        <fd:content>

            <VBox>

                <f:SimpleForm
                    id="orderDetailForm"
                    width="auto"
                    title="{i18n>formtitleDetails}"                
                    labelSpanL="4"
                    labelSpanM="4"
                    emptySpanL="4"
                    emptySpanM="4"
                    columnsL="1"
                    columnsM="1"
                    class="sapUiResponsiveMargin">

                <f:content>
                    <Label text="{i18n>lblOrderNumber}"/>
                    <Text text="{localOrders>OrderNumber}"/>

                    <Label text="{i18n>lblCreationDate}"/>
                    <Text text="{path: 'localOrders>CreationDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd MMM yyyy'}}"/>

                    <Label text="{i18n>lblReceivingPlant}"/>
                    <Text text="{localOrders>ReceivingPlantCode} - {localOrders>ReceivingPlantName}"/>

                    <Label text="{i18n>lblDeliveringPlant}"/>
                    <Text text="{localOrders>DeliveringPlantCode} - {localOrders>DeliveringPlantName}"/>

                    <Label text="{i18n>lblStatus}"/>
                    <Text text="{localOrders>Status}"/>
                </f:content>

                </f:SimpleForm>

                <!-- Products Table -->
                <Table
                    id="idProductsTable"
                    headerText="Product (3)"
                    width="auto"
                    class="sapUiResponsiveMargin sapUiLargePaddingTop"
>

                    <columns>
                        <Column width="12em">
                            <Text text="{i18n>colProductName}"/>
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true">
                            <Text text="{i18n>colQuantity}"/>
                        </Column>
                        <Column minScreenWidth="Tablet" demandPopin="true" hAlign="End">
                            <Text text="{i18n>colPriceperQuantity}"/>
                        </Column>
                        <Column hAlign="End">
                            <Text text="{i18n>colTotalPrice}"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{localOrders>ProductName}"/>
                                <Text text="{localOrders>Quantity}"/>
                                <Text text="{localOrders>PricePerQuantity}"/>
                                <Text text="{localOrders>TotalPrice}"/>
                            </cells>
                        </ColumnListItem>
                        <ColumnListItem>
                            <cells>
                                <Text text="{localOrders>ProductName}"/>
                                <Text text="{localOrders>Quantity}"/>
                                <Text text="{localOrders>PricePerQuantity}"/>
                                <Text text="{localOrders>TotalPrice}"/>
                            </cells>
                        </ColumnListItem>
                        <ColumnListItem>
                            <cells>
                                <Text text="{localOrders>Products>ProductName}"/>
                                <Text text="{localOrders>Quantity}"/>
                                <Text text="{localOrders>PricePerQuantity}"/>
                                <Text text="{localOrders>TotalPrice}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </fd:content>

        <fd:footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="{i18n>tlpEdit}" press="onEdit"/>
                <Button text="{i18n>tlpCancel}" press="onCancel"/>
            </OverflowToolbar>
        </fd:footer>

    </fd:DynamicPage>

</mvc:View>