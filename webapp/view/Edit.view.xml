<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core" xmlns:fd="sap.f" controllerName="sapui5.casestudy.casestudy.controller.Edit" height="100%">

    <fd:DynamicPage id="dynamicPageIdEdit" showFooter="true">

        <fd:title>
            <fd:DynamicPageTitle>
                <fd:heading>
                    <Title text="Edit Order" level="H1" titleStyle="H1"/>
                </fd:heading>
            </fd:DynamicPageTitle>
        </fd:title>

        <fd:content>

          <VBox>

                <f:SimpleForm id="idSimpleForm" editable="true" layout="ResponsiveGridLayout" title="{i18n>editOrder}" labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" width="auto" class="sapUiResponsiveMargin">

                    <f:content>
                        <Label text="Order Number"/>
                        <Input xmlns="sap.m" value="{localOrders>OrderNumber}" id="orderNumberInput" editable="false"/>

                        <Label text="Created On"/>
                        <Input xmlns="sap.m" value="{localOrders>CreationDate}" id="createdOnInput" editable="false"/>

                        <Label text="Receiving Plant"/>
                        <Input xmlns="sap.m" value="{localOrders>ReceivingPlantCode} - {localOrders>ReceivingPlantName}" id="receivingPlantInput" editable="false"/>

                        <Label text="Delivering Plant"/>
                        <Input xmlns="sap.m" value="{localOrders>DeliveringPlantCode} - {localOrders>DeliveringPlantName}" id="deliveringPlantInput" editable="false"/>

                        <Label text="Status"/>
                        <Select xmlns="sap.m" id="select0" enabled="true" editable="true" selectedKey="{localOrders>Status}">
                            <items>
                                <core:Item xmlns:core="sap.ui.core" key="{Constants>/STATUS/CREATED}" text="Created" id="item3"/>
                                <core:Item xmlns:core="sap.ui.core" key="{Constants>/STATUS/RELEASED}" text="Released" id="item4"/>
                                <core:Item xmlns:core="sap.ui.core" key="{Constants>/STATUS/PARTIAL}" text="Partially Completed" id="item5"/>
                                <core:Item xmlns:core="sap.ui.core" key="{Constants>/STATUS/DELIVERED}" text="Delivered" id="item6"/>
                            </items>
                        </Select>
                        
                    </f:content>

                </f:SimpleForm>

                <Table id="idProductsTable" mode="MultiSelect" items="{orderProducts>/}" width="auto" class="sapUiResponsiveMargin sapUiLargePaddingTop">

                    <headerToolbar>
                        <Toolbar>
                            <Title text="{ parts: ['orderProducts>/','i18n>products'], formatter: '.formatter.getProductTitle'}" />
                            <ToolbarSpacer/>
                            <Button id="addItemButton" icon="sap-icon://add" press="onAddItem" />
                            <Button id="deleteItemButton" icon="sap-icon://delete" press="onDeleteItem" />
                        </Toolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="25%" demandPopin="true">
                            <Text text="Product Name"/>
                        </Column>
                        <Column width="25%" demandPopin="true">
                            <Text text="Quantity"/>
                        </Column>
                        <Column width="25%" demandPopin="true">
                            <Text text="Price Per Quantity"/>
                        </Column>
                        <Column width="25%" demandPopin="true">
                            <Text text="Total Price"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <VBox>
                                    <Text text="{orderProducts>Product/ProductName}" visible="{path:'orderProducts>isNew', formatter:'.formatter.showText'}" />
                                    <Input value="{orderProducts>Product/ProductName}" visible="{path:'orderProducts>isNew', formatter:'.formatter.showInput'}" />
                                </VBox>

                                <VBox>
                                    <Text text="{orderProducts>Quantity}" visible="{path:'orderProducts>isNew', formatter:'.formatter.showText'}" />
                                    <Input value="{orderProducts>Quantity}" type="Number" visible="{path:'orderProducts>isNew', formatter:'.formatter.showInput'}" change="onCalculateTotal"/>
                                </VBox>

                                <VBox>
                                    <Text text="{orderProducts>UnitPrice}" visible="{path:'orderProducts>isNew', formatter:'.formatter.showText'}" />
                                    <Input value="{orderProducts>UnitPrice}" type="Number" visible="{path:'orderProducts>isNew', formatter:'.formatter.showInput'}" change="onCalculateTotal"/>
                                </VBox>

                                <Text text="{= ${orderProducts>Quantity} * ${orderProducts>UnitPrice} }" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

           </VBox>

        </fd:content>

        <fd:footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button id="saveButton" text="Save" type="Emphasized" press="onPressSave"/>
                <Button id="cancelButton" text="Cancel" type="Reject" press="onPressCancel"/>
            </OverflowToolbar>
        </fd:footer>

    </fd:DynamicPage>

</mvc:View>